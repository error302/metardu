    "test:rls": "SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY npx ts-node scripts/test-rls-isolation.ts",
    "seed:test-users": "SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL npx ts-node scripts/seed-test-users.ts"
  },
  "dependencies": {

# Test Runner Dockerfile - Simplified
FROM node:20-alpine

# Install Chromium dependencies only
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Install Playwright globally but skip its built-in deps installer since our OS is Alpine
RUN npm install -g playwright

WORKDIR /app

COPY package*.json ./
RUN npm ci --legacy-peer-deps

COPY scripts/live-browser-test.ts ./scripts/
COPY src/lib/ ./src/lib/
COPY src/types/ ./src/types/

ENV CI=true
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

CMD ["npm", "run", "test:live"]

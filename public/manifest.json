{
  "id": "/",
  "scope": "/",
  "name": "METARDU Access — Survey & Cadastral Platform",
  "short_name": "METARDU Access",
  "description": "Professional land surveying platform with METARDU Access mobile field collection. Traverse adjustment, leveling, COGO, deed plans, GNSS stakeout, NLIMS export, and field-to-finish workflow compliant with Survey Act Cap. 299.",
  "start_url": "/dashboard?source=pwa",
  "scope_extensions": [
    "/field",
    "/tools",
    "/map",
    "/projects",
    "/documents"
  ],
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "background_color": "#0a0a0f",
  "theme_color": "#e8841a",
  "orientation": "any",
  "lang": "en",
  "dir": "ltr",
  "categories": [
    "productivity",
    "utilities",
    "maps",
    "navigation"
  ],
  "icons": [
    {
      "src": "/metardu-icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-256.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/dashboard-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard with project list and activity feed"
    },
    {
      "src": "/screenshots/map-mobile.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Field map with GNSS stakeout on mobile"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Home",
      "description": "View your projects, recent activity, and quick actions",
      "url": "/dashboard?source=pwa_shortcut",
      "icons": [
        {
          "src": "/metardu-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Map",
      "short_name": "Map",
      "description": "Open the interactive cadastral map",
      "url": "/map?source=pwa_shortcut",
      "icons": [
        {
          "src": "/metardu-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Field Book",
      "short_name": "Field",
      "description": "Record traverse and leveling observations",
      "url": "/fieldbook?source=pwa_shortcut",
      "icons": [
        {
          "src": "/metardu-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Toolbox",
      "short_name": "Tools",
      "description": "Search 40+ survey calculation tools",
      "url": "/tools/all?source=pwa_shortcut",
      "icons": [
        {
          "src": "/metardu-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Settings",
      "short_name": "Settings",
      "description": "Manage profile, company info, and notifications",
      "url": "/settings/profile?source=pwa_shortcut",
      "icons": [
        {
          "src": "/metardu-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/vnd.ms-excel": [
          ".xls"
        ],
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [
          ".xlsx"
        ],
        "text/csv": [
          ".csv"
        ],
        "application/json": [
          ".json"
        ],
        "application/geo+json": [
          ".geojson"
        ],
        "application/dxf": [
          ".dxf"
        ],
        "application/vnd.google-earth.kml+xml": [
          ".kml"
        ]
      },
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "share_target": {
    "action": "/import/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "text/csv",
            "application/json",
            "application/geo+json",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "application/vnd.google-earth.kml+xml"
          ]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+metardu",
      "url": "/dashboard?deeplink=%s"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 480
  }
}
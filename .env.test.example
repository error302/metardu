# METARDU Test Environment Config Template
# Used for testing the Docker stack locally.
#
# P0-5 (2026-07-24): The previous template shipped the SAME weak
# secrets that the H8 audit flagged in production. Now uses random
# placeholders — copy this file to .env.test and fill in real random
# values before running `docker compose -f docker-compose.testing.yml up`.
#
# Generate secrets with:
#   openssl rand -base64 32

DATABASE_URL=postgresql://metardu_test:metardu_test@localhost:5433/metardu_test
AUTH_SECRET=                                       # [REQUIRED] openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
PYTHON_COMPUTE_URL=http://localhost:8001
WORKER_SECRET=                                     # [REQUIRED] openssl rand -base64 32
DISABLE_PWA=true

# Docker compose testing stack vars (match docker-compose.testing.yml)
TEST_POSTGRES_DB=metardu_test
TEST_POSTGRES_USER=metardu_test
TEST_POSTGRES_PASSWORD=metardu_test
TEST_AUTH_SECRET=                                  # [REQUIRED] openssl rand -base64 32
TEST_WORKER_SECRET=                                # [REQUIRED] openssl rand -base64 32

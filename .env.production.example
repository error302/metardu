# METARDU Production Environment Configuration
# Copy to .env.production and fill in your values

# ─── Core ───
DATABASE_URL=postgresql://metardu:YOUR_PASSWORD@localhost:5432/metardu
AUTH_SECRET=YOUR_32_CHAR_SECRET_HERE
NEXTAUTH_URL=https://metardu.duckdns.org
NEXT_PUBLIC_APP_URL=https://metardu.duckdns.org
NEXT_PUBLIC_WS_URL=wss://metardu.duckdns.org/ws/collaboration

# ─── OAuth Providers (optional but recommended) ───
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
AZURE_AD_CLIENT_ID=your-azure-app-id
AZURE_AD_CLIENT_SECRET=your-azure-secret
AZURE_AD_TENANT_ID=common

# ─── Admin ───
ADMIN_EMAILS=admin@metardu.com
PLATFORM_OWNER_EMAIL=owner@metardu.com

# ─── Payments ───
# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your-mpesa-key
MPESA_CONSUMER_SECRET=your-mpesa-secret
MPESA_SHORTCODE=your-paybill
MPESA_PASSKEY=your-passkey
MPESA_ENVIRONMENT=production

# Stripe
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# ─── AI (optional) ───
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Monitoring (optional) ───
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── Python Worker ───
PYTHON_COMPUTE_URL=http://metardu-worker:8000
WORKER_SECRET=your-worker-secret

# ─── Docker ───
HOSTNAME=0.0.0.0
NODE_ENV=production
DISABLE_PWA=false

# ─── CORS ───
CORS_ORIGIN=https://metardu.duckdns.org

# ─── Email (optional) ───
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email-user
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@metardu.duckdns.org

# ─── SMS (optional, Africa's Talking) ───
AFRICAS_TALKING_USERNAME=your-username
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_SENDER_ID=METARDU

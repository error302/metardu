/upload/
/public/uploads/

# Local database files
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# Misc
.DS_Store
*.pem
*.key
*.p12
*.jks
*.keystore

# Debug
npm-debug.log*
*.log

# Environment files with secrets - NEVER commit these
.env
.env.local
.env.*.local
.env.production
.env.staging

# Scripts with potential credentials (use env vars instead)
scripts/create-tables.js
scripts/migrate-db.js

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Test coverage
coverage/

# IDE
.idea/
.continue/

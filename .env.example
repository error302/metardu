# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...

# M-Pesa (Kenya)
MPESA_CONSUMER_KEY=...
MPESA_CONSUMER_SECRET=...
MPESA_SHORT_CODE=...
MPESA_INITIATOR_NAME=...
MPESA_SECURITY_CREDENTIAL=...
MPESA_PASSKEY=...

# Airtel Money (Uganda)
AIRTEL_CLIENT_ID=...
AIRTEL_CLIENT_SECRET=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Monitoring
NEXT_PUBLIC_LOG_ENDPOINT=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Python Geospatial Engine
# Used for TIN, contours, raster analysis, and volume computation.
# Run locally: docker-compose up python-engine
# Deploy to Railway/Render and set the public URL here.
PYTHON_COMPUTE_URL=http://localhost:8000

# Upstash Redis (rate limiting)
# Create a free Redis DB at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth (Supabase service role — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend) — https://resend.com
RESEND_API_KEY=re_your_key_here

# Sentry error monitoring — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# SEO
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Email sender address (must be verified in Resend)
RESEND_FROM_EMAIL=GeoNova <hello@geonova.app>

# Community WhatsApp number (without +, e.g. 254712345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000

# Admin emails — bypass all subscription/paywall checks (comma-separated)
ADMIN_EMAILS=admin@yourdomain.com

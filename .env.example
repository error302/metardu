# ─── METARDU Environment Variables ───
# Copy this file to .env (for Docker Compose) or .env.local (for dev server)
# and fill in the values. Required variables are marked with [REQUIRED].
#
# AUDIT FIX (H8, 2026-07-02): All secrets now use placeholder values.
# Generate strong random secrets with:
#   openssl rand -base64 32
# Never commit real secrets to version control.

# ─── Docker Compose secrets (read by docker-compose.yml) ───
# PostgreSQL credentials (used by docker-compose.yml + DATABASE_URL below)
POSTGRES_DB=metardu
POSTGRES_USER=metardu
POSTGRES_PASSWORD=          # [REQUIRED] generate: openssl rand -base64 24

# Auth secret (used by NextAuth for JWT signing) [REQUIRED]
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Worker secret (shared between Next.js app and Python compute worker)
WORKER_SECRET=              # [REQUIRED] generate: openssl rand -base64 32

# ─── Core ───
# PostgreSQL connection string
# For Docker: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@metardu-postgres:5432/${POSTGRES_DB}
# For local dev: postgresql://metardu:<password>@localhost:5432/metardu
DATABASE_URL=postgresql://metardu:CHANGE_ME@localhost:5432/metardu

NEXTAUTH_URL=http://localhost:3000

# Admin emails (comma-separated) — these users get admin role
ADMIN_EMAILS=

# ─── App URLs ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Database (optional overrides) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metardu_dev
DB_USER=postgres
DB_PASSWORD=

# ─── Payments: Stripe ───
# Setup: https://dashboard.stripe.com/apikeys
# 1. Copy the Secret key here
# 2. Create a webhook endpoint: https://your-domain.com/api/webhooks/stripe
# 3. Copy the webhook signing secret here
# 4. Copy the Publishable key for the client
STRIPE_SECRET_KEY=                    # [REQUIRED for card payments] sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=                # [REQUIRED for webhook verification] whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # [REQUIRED for client] pk_live_... or pk_test_...

# ─── Payments: PayPal ───
# Setup: https://developer.paypal.com/dashboard/applications/live
# 1. Create a REST API app → copy Client ID + Secret
# 2. Add a webhook: https://your-domain.com/api/webhooks/paypal
# 3. Subscribe to: CHECKOUT.ORDER.APPROVED, CHECKOUT.ORDER.COMPLETED, PAYMENT.CAPTURE.REFUNDED
# 4. Copy the Webhook ID here
# 5. Set PAYPAL_MODE to 'live' for production, 'sandbox' for testing
PAYPAL_CLIENT_ID=                     # [REQUIRED for PayPal] 
PAYPAL_CLIENT_SECRET=                 # [REQUIRED for PayPal]
PAYPAL_MODE=sandbox                   # 'sandbox' or 'live'
PAYPAL_WEBHOOK_ID=                    # [REQUIRED in production] from PayPal dashboard
NEXT_PUBLIC_PAYPAL_CLIENT_ID=         # [REQUIRED for client] same as PAYPAL_CLIENT_ID

# ─── Payments: M-Pesa (Safaricom Daraja API) ───
# Setup: https://developer.safaricom.co.ke/
# 1. Create an app → copy Consumer Key + Consumer Secret
# 2. Get your Short Code (Paybill or Till number) from Safaricom
# 3. Get the Passkey from the Daraja portal (Lipa Na M-Pesa Online → Go Live)
# 4. Set MPESA_ENV to 'production' when going live (requires Daraja go-live approval)
# 5. Register the callback URL: https://your-domain.com/api/payments/mpesa/callback
# 6. (Optional) Set MPESA_CALLBACK_IP_WHITELIST if Safaricom adds new IPs
MPESA_CONSUMER_KEY=                   # [REQUIRED for M-Pesa]
MPESA_CONSUMER_SECRET=                # [REQUIRED for M-Pesa]
MPESA_SHORT_CODE=                     # [REQUIRED] Your Paybill/Till number
MPESA_SHORTCODE=                      # (alias for MPESA_SHORT_CODE)
MPESA_INITIATOR_NAME=                 # [For B2B/C2B only] 
MPESA_SECURITY_CREDENTIAL=            # [For B2B only]
MPESA_PASSKEY=                        # [REQUIRED for STK Push] Lipa Na M-Pesa Online passkey
MPESA_ENV=sandbox                     # 'sandbox' or 'production'
MPESA_CALLBACK_IP_WHITELIST=          # (Optional) Comma-separated Safaricom IPs. Defaults to known list.

# ─── Payments: Airtel Money ───
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# ─── Email: SMTP ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ─── Email: Resend (alternative to SMTP) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL="METARDU <noreply@example.com>"

# ─── Monitoring: Sentry ───
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Monitoring: Logging ───
NEXT_PUBLIC_LOG_ENDPOINT=

# ─── Rate Limiting: Upstash Redis ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Caching: Redis ───
REDIS_URL=redis://localhost:6379

# ─── Storage: Google Cloud Storage ───
STORAGE_ROOT=./uploads
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_KEY_FILE=

# ─── AI / Compute ───
NVIDIA_API_KEY=
NEXT_PUBLIC_AI_SERVICE_URL=https://metardu-ai.up.railway.app
PYTHON_COMPUTE_URL=
PYTHON_SERVICE_URL=
API_ADMIN_KEY=

# ─── Integrations: NLIMS ───
NLIMS_API_KEY=

# ─── Integrations: Ardhisasa ───
ARDHISASA_API_KEY=
ARDHISASA_CLIENT_ID=
ARDHISASA_CLIENT_SECRET=
ARDHISASA_BASE_URL=https://ardhisasa.go.ke/api/v1
ARDHISASA_ENVIRONMENT=sandbox

# ─── Integrations: KENCORS ───
KENCORS_API_KEY=

# ─── WhatsApp ───
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── Google ───
GOOGLE_SITE_VERIFICATION=

# ─── Auth: Google OAuth ───
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google as an authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Auth: Microsoft / Azure AD OAuth ───
# Create an app registration at https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Add http://localhost:3000/api/auth/callback/azure-ad as a redirect URI
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# ─── PWA / Mobile ───
DISABLE_PWA=false
ENABLE_PWA_ON_WINDOWS=false
MOBILE_BUILD=false

# ─── Misc ───
ANALYZE=false
NEXT_PUBLIC_WHATSAPP_NUMBER=

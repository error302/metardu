# ─── METARDU Environment Variables ───
# Copy this file to .env.local and fill in the values.
# Required variables are marked with [REQUIRED].

# ─── Core ───
# PostgreSQL connection string (REQUIRED)
# For Docker: postgresql://metardu:metardu_secure_2024@metardu_postgres:5432/metardu
# For local dev: postgresql://metardu:metardu_secure_2024@localhost:5432/metardu
DATABASE_URL=postgresql://metardu:metardu_secure_2024@localhost:5432/metardu

# NextAuth / Auth secret (generate with: openssl rand -base64 32) [REQUIRED]
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Admin emails (comma-separated) — these users get admin role
ADMIN_EMAILS=

# ─── App URLs ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Database (optional overrides) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metardu_dev
DB_USER=postgres
DB_PASSWORD=

# ─── Payments: Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Payments: PayPal ───
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_WEBHOOK_ID=

# ─── Payments: M-Pesa ───
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORT_CODE=
MPESA_SHORTCODE=
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=
MPESA_PASSKEY=
MPESA_ENV=sandbox

# ─── Payments: Airtel Money ───
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# ─── Email: SMTP ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ─── Email: Resend (alternative to SMTP) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL="METARDU <noreply@example.com>"

# ─── Monitoring: Sentry ───
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Monitoring: Logging ───
NEXT_PUBLIC_LOG_ENDPOINT=

# ─── Rate Limiting: Upstash Redis ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Caching: Redis ───
REDIS_URL=redis://localhost:6379

# ─── Storage: Google Cloud Storage ───
STORAGE_ROOT=./uploads
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_KEY_FILE=

# ─── AI / Compute ───
NVIDIA_API_KEY=
NEXT_PUBLIC_AI_SERVICE_URL=https://metardu-ai.up.railway.app
PYTHON_COMPUTE_URL=
PYTHON_SERVICE_URL=
API_ADMIN_KEY=

# ─── Integrations: NLIMS ───
NLIMS_API_KEY=

# ─── Integrations: Ardhisasa ───
ARDHISASA_API_KEY=
ARDHISASA_CLIENT_ID=
ARDHISASA_CLIENT_SECRET=
ARDHISASA_BASE_URL=https://ardhisasa.go.ke/api/v1
ARDHISASA_ENVIRONMENT=sandbox

# ─── Integrations: KENCORS ───
KENCORS_API_KEY=

# ─── WhatsApp ───
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── Google ───
GOOGLE_SITE_VERIFICATION=

# ─── PWA / Mobile ───
DISABLE_PWA=false
ENABLE_PWA_ON_WINDOWS=false
MOBILE_BUILD=false

# ─── Misc ───
ANALYZE=false
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ============================================================
# APP URL
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=admin@yourdomain.com

# ============================================================
# AUTH & DATABASE (REQUIRED)
# ============================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metardu?schema=public"

# NextAuth Secret for signing tokens
AUTH_SECRET="your-super-secret-32-char-minimum-key-here"

# Database connection pool settings (optional)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=metardu

# ============================================================
# AI SERVICE (FastAPI on Railway)
# ============================================================
NEXT_PUBLIC_AI_SERVICE_URL=https://metardu-ai.up.railway.app

# ============================================================
# FIREBASE ANALYTICS
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

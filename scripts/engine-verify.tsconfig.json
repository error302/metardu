{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": ".out"
  },
  "include": [
    "engine-verify.ts",
    "../src/lib/engine/**/*.ts"
  ]
}

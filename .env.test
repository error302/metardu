# =============================================================================
# METARDU — Test Environment Variables
# Used by docker-compose.testing.yml — NO real secrets
# =============================================================================

NODE_ENV=test
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# Auth — test-only secret (NOT used in production)
AUTH_SECRET=test-secret-do-not-use-in-production-abc123xyz

# Database — overridden by docker-compose but needed for build
DATABASE_URL=postgresql://metardu_test:TestPass_2026!secure@postgres:5432/metardu_test

# Admin
ADMIN_EMAILS=test@metardu.com

# External services — disabled/mock in test mode
NVIDIA_API_KEY=
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder
PYTHON_COMPUTE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=test

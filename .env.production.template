# =============================================================================
# METARDU — Production Environment Template
# =============================================================================
# Copy this file to .env.local on the VM and fill in real values.
# Required variables are marked with [REQUIRED].

# --- Core ---
NEXT_PUBLIC_APP_URL=https://metardu.duckdns.org
NEXTAUTH_URL=https://metardu.duckdns.org
AUTH_TRUST_HOST=true

# [REQUIRED] Random 32+ character secret for NextAuth JWT signing
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=

# --- Database (VM PostgreSQL) [REQUIRED] ---
DATABASE_URL=postgresql://metardu:YOUR_DB_PASSWORD@localhost:5432/metardu
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metardu
DB_USER=metardu
DB_PASSWORD=YOUR_DB_PASSWORD

# --- Admin ---
ADMIN_EMAILS=mohameddosho20@gmail.com

# --- Stripe (optional — payments disabled if empty) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PayPal (optional) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- M-Pesa (optional) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORT_CODE=
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=
MPESA_PASSKEY=

# --- Airtel Money (optional) ---
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# --- Email via Resend (optional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@metardu.duckdns.org

# --- Python Compute Engine (optional — volume/contour features) ---
PYTHON_COMPUTE_URL=http://localhost:8000

# --- Rate Limiting via Upstash Redis (optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Logging & Monitoring (optional) ---
NEXT_PUBLIC_LOG_ENDPOINT=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# --- WhatsApp Support (optional) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Google Search Console (optional) ---
GOOGLE_SITE_VERIFICATION=


API_ADMIN_KEY=
